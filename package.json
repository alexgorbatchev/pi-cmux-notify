{
  "name": "@alexgorbatchev/pi-cmux-notify",
  "version": "1.0.0",
  "description": "pi package for cmux notifications",
  "scripts": {
    "check": "bun --bun oxfmt --write . && bun --bun oxlint . && tsgo --noEmit",
    "test": "PI_OFFLINE=1 bun x pi --no-extensions -e ./extensions/index.ts --list-models > /dev/null 2>&1",
    "test:local": "bun x pi -e ./extensions/index.ts"
  },
  "author": "Alex Gorbatchev <alex.gorbatchev@gmail.com>",
  "contributors": [
    "Javi Molina <javimolina@fastmail.com>"
  ],
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "cmux",
    "terminal",
    "notifications"
  ],
  "homepage": "https://github.com/alexgorbatchev/pi-cmux-notify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexgorbatchev/pi-cmux-notify.git"
  },
  "bugs": {
    "url": "https://github.com/alexgorbatchev/pi-cmux-notify/issues"
  },
  "files": [
    "extensions/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@alexgorbatchev/typescript-ai-policy": "^1.0.5",
    "@mariozechner/pi-coding-agent": "0.65.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "@types/node": "25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260407.1",
    "typescript": "6.0.2"
  }
}
